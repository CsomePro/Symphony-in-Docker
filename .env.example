# Required
LINEAR_API_KEY=lin_api_xxx
SOURCE_REPO_URL=git@github.com:YOUR_ORG/YOUR_REPO.git

# Optional but recommended for non-interactive startup
OPENAI_API_KEY=
GITHUB_TOKEN=
GH_TOKEN=

# Optional git identity used by commits created inside the container
GIT_AUTHOR_NAME=Codex
GIT_AUTHOR_EMAIL=codex@users.noreply.github.com
GIT_COMMITTER_NAME=Codex
GIT_COMMITTER_EMAIL=codex@users.noreply.github.com
